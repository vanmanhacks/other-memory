# ───────────────────────────────────────────────────────────
# Other Memory — Environment Configuration
# ───────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — NEVER commit real secrets.
#
# On NixOS: /etc/other-memory/env is created and populated automatically
#           by other-memory-secret.service (see other-memory.nix).
# NOTE: Uses /etc/other-memory/ namespace for standalone secret management.
#       The directory is created by other-memory-secret.service on first boot.
#
# Manual deployment (non-NixOS):
#   cp .env.example .env && chmod 600 .env
# ───────────────────────────────────────────────────────────

# ─── Searxng ───────────────────────────────────────────────

# Random 32-byte hex secret for Searxng session tokens / CSRF.
# Generate your own (no external service needed):
#   openssl rand -hex 32
# NixOS: auto-generated at boot by other-memory-secret.service
SEARXNG_SECRET=  # ← paste output of: openssl rand -hex 32

# ─── Crawl4ai ──────────────────────────────────────────────

# Internal API token for Crawl4ai — localhost only.
# Generate your own:
#   openssl rand -hex 16
CRAWL4AI_TOKEN=  # ← paste output of: openssl rand -hex 16

# ─── Redis ─────────────────────────────────────────────────

# Redis is internal-only (binds to 127.0.0.1:6380).
# No authentication configured by default — localhost access only.
# If you need auth, add: --requirepass <password> to the command in docker-compose.yml

# ─── Ports Used ────────────────────────────────────────────
# Searxng:   127.0.0.1:8888  (GHOLA conflict check: none)
# Crawl4ai:  127.0.0.1:11235 (GHOLA conflict check: none)
# Redis:     127.0.0.1:6380  (GHOLA redis: 127.0.0.1:6379)
